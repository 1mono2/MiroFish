{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "cd frontend && npm ci && npm run build",
    "watchPatterns": [
      "/frontend/**",
      "/locales/**"
    ]
  },
  "deploy": {
    "startCommand": "cd frontend && npx serve -s dist -l $PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
